# VerifiMind-PEAS MCP Server — Environment Variables
# Copy to .env for local development. Never commit .env to version control.
# GCP Cloud Run: set these as environment variables in the service config.

# =============================================================================
# LLM Providers (BYOK — Bring Your Own Key)
# =============================================================================

# Anthropic (Claude) — X Agent default provider
ANTHROPIC_API_KEY=sk-ant-...

# Google (Gemini) — Z and CS Agent default provider
GEMINI_API_KEY=AIza...

# Groq — fast inference fallback
GROQ_API_KEY=gsk_...

# OpenAI — optional additional provider
OPENAI_API_KEY=sk-...

# Perplexity — optional research provider
PERPLEXITY_API_KEY=pplx-...

# =============================================================================
# Tier-Gating (Phase 1 — env var keys)
# =============================================================================

# Comma-separated Pioneer access keys for Phase 1 validation.
# Phase 2 (v0.5.12+): replaced by Polar customer state API when
# POLAR_ACCESS_TOKEN is set. Both can coexist during transition.
# Example: vm-pioneer-test1-2026,vm-pioneer-alton-2026
PIONEER_ACCESS_KEYS=vm-pioneer-test1-2026

# =============================================================================
# Polar Integration (Phase 2 — v0.5.12+)
# Set these once Polar account is approved and Pioneer product is configured.
# =============================================================================

# Polar Organization Access Token (polar_oat_... format)
# Create at: polar.sh/dashboard → Settings → API
POLAR_ACCESS_TOKEN=polar_oat_...

# Webhook signing secret (whsec_... format)
# Generated when registering the webhook endpoint in Polar dashboard.
# Endpoint URL: https://verifimind.ysenseai.org/api/webhooks/polar
# Event: customer.state_changed
POLAR_WEBHOOK_SECRET=whsec_...

# Polar environment: "production" or "sandbox"
# Use "sandbox" during development (sandbox-api.polar.sh)
POLAR_ENVIRONMENT=sandbox

# Polar organization ID (org_... format)
POLAR_ORGANIZATION_ID=org_...

# Pioneer subscription product ID in Polar dashboard (prod_... format)
POLAR_PIONEER_PRODUCT_ID=prod_...

# Tier cache TTL in seconds (default: 300 = 5 minutes)
# Webhooks keep cache fresh; this controls max staleness on cache miss.
POLAR_CACHE_TTL=300

# =============================================================================
# Early Adopter Registration (v0.5.6+)
# =============================================================================

# Google Cloud Firestore project (for EA registration storage)
# Configured via gcloud CLI — not hardcoded
# GCP_PROJECT_ID=ysense-platform-v4-1

# =============================================================================
# Server Config
# =============================================================================

# Server port (default: 8080 for Cloud Run)
PORT=8080

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
